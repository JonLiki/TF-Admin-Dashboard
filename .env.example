# Database connection string
# Replace user, password, host, port, and database name as needed
DATABASE_URL="postgresql://user:password@localhost:5432/tf_dashboard?schema=public"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Seed credentials (optional in development, SEED_ADMIN_PASSWORD is required
# when seeding with NODE_ENV=production — defaults are refused there)
SEED_ADMIN_PASSWORD=""
SEED_PARTICIPANT_PASSWORD=""
